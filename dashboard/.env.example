# Copy to .env.local and fill in. The dashboard BFF uses these to authenticate
# to Dokploy server-side (session-cookie auth). Credentials never reach the browser.
DOKPLOY_URL=http://localhost:3000
DOKPLOY_EMAIL=admin@example.com
DOKPLOY_PASSWORD=change-me

# Host public/advertise IP. When set, deploying an app mints a public URL with
# no manual DNS (a Dokploy *.traefik.me host, or <app>.<ip>.sslip.io). Leave it
# unset to disable auto-URL (the dev/Docker Desktop default, where Traefik is
# not managed). The switchyard CLI sets this automatically on Linux.
# SWITCHYARD_HOST_IP=203.0.113.10
