# Copy to .env.local and fill in.
#
# Users sign into the dashboard at /login with their OWN Dokploy account; the
# BFF holds each user's Dokploy session server-side. DOKPLOY_EMAIL/PASSWORD are
# admin credentials used ONLY for the /api/health?deep=1 system probe.
# Credentials never reach the browser.
DOKPLOY_URL=http://localhost:3000
DOKPLOY_EMAIL=admin@example.com
DOKPLOY_PASSWORD=change-me

# Secret that signs/encrypts the Switchyard session cookie. Required. The CLI
# generates one automatically; from source, set any long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SWITCHYARD_SESSION_SECRET=change-me-to-a-long-random-string

# Host public/advertise IP. When set, deploying an app mints a public URL with
# no manual DNS (a Dokploy *.traefik.me host, or <app>.<ip>.sslip.io). Leave it
# unset to disable auto-URL (the dev/Docker Desktop default, where Traefik is
# not managed). The switchyard CLI sets this automatically on Linux.
# SWITCHYARD_HOST_IP=203.0.113.10

# Optional: durable metrics/logs persistence + crash-loop alerts. Leave unset in
# dev (persistence off, live behaviour unchanged). The CLI sets this on the
# managed container to the switchyard-metrics Postgres.
# SWITCHYARD_STORE_URL=postgresql://switchyard:PASSWORD@switchyard-metrics:5432/switchyard
# SWITCHYARD_ALERTS=1                       # 0/false/off disables crash-loop alerts
# SWITCHYARD_ALERT_NOTIFICATION=            # Dokploy channel name/id (default: first)
# SWITCHYARD_ALERT_RESTART_THRESHOLD=3      # consecutive unhealthy samples before firing
# SWITCHYARD_COLLECT_INTERVAL_MS=20000      # collector sampling interval
