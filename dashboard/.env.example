# Copy to .env.local and fill in.
#
# Users sign into the dashboard at /login with their OWN Dokploy account; the
# BFF holds each user's Dokploy session server-side. DOKPLOY_EMAIL/PASSWORD are
# admin credentials used ONLY for the /api/health?deep=1 system probe.
# Credentials never reach the browser.
DOKPLOY_URL=http://localhost:3000
DOKPLOY_EMAIL=admin@example.com
DOKPLOY_PASSWORD=change-me

# Secret that signs/encrypts the Switchyard session cookie. Required. The CLI
# generates one automatically; from source, set any long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SWITCHYARD_SESSION_SECRET=change-me-to-a-long-random-string
