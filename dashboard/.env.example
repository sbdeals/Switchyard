# Copy to .env.local and fill in. The dashboard BFF uses these to authenticate
# to Dokploy server-side (session-cookie auth). Credentials never reach the browser.
DOKPLOY_URL=http://localhost:3000
DOKPLOY_EMAIL=admin@example.com
DOKPLOY_PASSWORD=change-me

# Optional: durable metrics/logs persistence + crash-loop alerts. Leave unset in
# dev (persistence off, live behaviour unchanged). The CLI sets this on the
# managed container to the switchyard-metrics Postgres.
# SWITCHYARD_STORE_URL=postgresql://switchyard:PASSWORD@switchyard-metrics:5432/switchyard
# SWITCHYARD_ALERTS=1                       # 0/false/off disables crash-loop alerts
# SWITCHYARD_ALERT_NOTIFICATION=            # Dokploy channel name/id (default: first)
# SWITCHYARD_ALERT_RESTART_THRESHOLD=3      # consecutive unhealthy samples before firing
# SWITCHYARD_COLLECT_INTERVAL_MS=20000      # collector sampling interval
